<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Task Detail</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-950 text-white">
    <div class="main w-full min-h-screen p-10">
        <a class="text-blue-500 hover:text-blue-400 inline-block mb-10" href="/">← Go back to home</a>
        
        <div class="max-w-3xl">
            <h1 class="text-5xl font-bold tracking-tighter mb-5 text-white"><%= filename %></h1>
            <p class="text-lg text-zinc-300 leading-relaxed font-light bg-zinc-900 p-6 rounded-xl border border-zinc-800">
                <%= filedata %>
            </p>
        </div>
    </div>
</body>
</html>