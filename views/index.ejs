<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Task Manager</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-950 text-white">
    <div class="main w-full min-h-screen p-10">
        <div class="form max-w-3xl mx-auto mb-10 bg-zinc-900 p-8 rounded-xl shadow-lg">
            <form action="/create" method="post" class="flex flex-col gap-4">
                <input class="w-full rounded-lg px-4 py-3 bg-zinc-800 border border-zinc-700 focus:outline-none focus:border-blue-500" type="text" name="title" placeholder="Task title">
                <textarea class="w-full rounded-lg px-4 py-3 bg-zinc-800 border border-zinc-700 focus:outline-none focus:border-blue-500 resize-none" name="details" rows="4" placeholder="Write your task detail here"></textarea>
                <input class="bg-blue-600 hover:bg-blue-500 cursor-pointer px-6 py-2 rounded-lg font-semibold transition" type="submit" value="Create Task">
            </form>
        </div>

        <div class="tasks flex flex-wrap gap-6 justify-center">
            <% if(files.length > 0){ %>
                <% files.forEach(function(val){ %>
                    <div class="task w-72 px-6 py-5 rounded-xl bg-zinc-900 border border-zinc-800 hover:border-zinc-600 transition">
                        <h1 class="text-white text-2xl font-bold mb-2 tracking-tight"><%= val %></h1>
                        <p class="text-zinc-400 text-sm leading-relaxed">Click below to read task details.</p>
                        <div class="flex w-full justify-between">
                            <a class="text-blue-500 hover:text-blue-400 font-medium inline-block mt-4" href="/file/<%= val %>">Read More →</a>
                        <a class="text-zinc-600" href="/edit/<%= val%>">edit</a>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <h3 class="text-zinc-600">no tasks yet.</h3>
            <% } %>
        </div>
    </div>
</body>
</html>